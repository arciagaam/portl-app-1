model Table {
  id              String               @id @default(cuid())
  eventId         String
  label           String               // e.g., "A1", "B2"
  capacity        Int                  // Number of tickets included
  ticketPrice     Int                  // Price per ticket in PHP
  requirementType TableRequirementType?
  minSpend        Int?                 // For MINIMUM_SPEND — consumable amount in PHP
  bottleCount     Int?                 // For BOTTLE_REQUIREMENT — number of bottles required
  description     String?              @db.Text
  imageUrl        String?
  transferrable   Boolean              @default(false)
  cancellable     Boolean              @default(false)
  notes           String?              @db.Text
  quantitySold    Int                  @default(0)
  status          InventoryStatus      @default(OPEN)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([eventId, label])
  @@index([eventId])
  @@index([status])
  @@map("tables")
}

enum TableRequirementType {
  MINIMUM_SPEND
  BOTTLE_REQUIREMENT
}
